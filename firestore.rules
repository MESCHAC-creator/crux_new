rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Meetings ──────────────────────────────────────────────────────────
    match /meetings/{meetingId} {
      // Anyone authenticated can read a meeting (to check if it exists / join)
      allow read: if request.auth != null;
      // Only the organizer can create the meeting doc
      allow create: if request.auth != null
                    && request.resource.data.organizerId == request.auth.uid;
      // Host/coHosts can update anything; any authenticated user can add/remove themselves from participants
      allow update: if request.auth != null
                    && (resource.data.organizerId == request.auth.uid
                        || ('coHosts' in resource.data && resource.data.coHosts.hasAny([request.auth.uid]))
                        || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['participants'])
                            && (request.resource.data.participants.hasAll(resource.data.participants)
                                || resource.data.participants.hasAll(request.resource.data.participants))));
      allow delete: if request.auth != null
                    && resource.data.organizerId == request.auth.uid;

      // Chat: any participant can write; all authenticated users can read
      match /chat/{messageId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
                      && request.resource.data.senderId == request.auth.uid;
        allow update, delete: if false; // messages are immutable
      }

      // Presence: each user writes only their own presence
      match /presence/{userId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == userId;
      }

      // Attendance: any authenticated user can read/write their own entry
      match /attendance/{userId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == userId;
      }

      // Camera/mic control signals: any participant can write
      match /camOffSignals/{signalId} {
        allow read, write: if request.auth != null;
      }

      // Meeting reports: only host can write
      match /reports/{reportId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null
                     && resource == null
                        ? request.resource.data.hostId == request.auth.uid
                        : resource.data.hostId == request.auth.uid;
      }
    }

    // ── User profiles ─────────────────────────────────────────────────────
    match /users/{userId} {
      // Any authenticated user can read profiles (needed for photo/name in calls)
      allow read: if request.auth != null;
      // Users can only write their own profile, but cannot self-promote isPro
      allow write: if request.auth != null && request.auth.uid == userId
                   && !('isPro' in request.resource.data
                        && request.resource.data.isPro == true
                        && (resource == null || resource.data.get('isPro', false) != true));
    }

    // ── Meeting reports (top-level) ───────────────────────────────────────
    match /meeting_reports/{reportId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.hostId == request.auth.uid;
      allow update, delete: if request.auth != null
                            && resource.data.hostId == request.auth.uid;
    }

    // ── WebRTC signaling rooms ────────────────────────────────────────────
    match /webrtc_rooms/{roomId} {
      allow read, write: if request.auth != null;
      match /offerCandidates/{id} {
        allow read, write: if request.auth != null;
      }
      match /answerCandidates/{id} {
        allow read, write: if request.auth != null;
      }
      match /reactions/{id} {
        allow read: if request.auth != null;
        allow write: if request.auth != null
                     && request.resource.data.userId == request.auth.uid;
      }
    }
  }
}
